GRANTORA_ENV=development
GRANTORA_PUBLIC_BASE_URL=http://localhost:9080
GRANTORA_BIND_ADDR=0.0.0.0
GRANTORA_PORT=8080
GRANTORA_LOG_LEVEL=INFO
GRANTORA_JSON_LOGS=true

DATABASE_URL=postgresql+psycopg://grantora:grantora@postgres:5432/grantora
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_SSLMODE=prefer
MIGRATIONS_AUTO_RUN=true

POSTGRES_DB=grantora
POSTGRES_USER=grantora
POSTGRES_PASSWORD=grantora
POSTGRES_PORT=5432

APISIX_PUBLIC_URL=http://localhost:9080
APISIX_ADMIN_URL=http://apisix:9180
APISIX_ADMIN_KEY=change-me
APISIX_SYNC_ENABLED=true
APISIX_SYNC_INTERVAL_SECONDS=30
APISIX_FAIL_CLOSED=true

SECRET_ENCRYPTION_KEY=change-me-32-byte-base64-key
GRANTORA_AGENT_TOKEN_PEPPER=change-me-agent-token-pepper
GRANTORA_ADMIN_BOOTSTRAP_TOKEN_HASH=hmac-sha256:replace-with-bootstrap-token-hash

METRICS_ENABLED=true
METRICS_PATH=/metrics
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365
USAGE_RETENTION_DAYS=365
REQUEST_ID_HEADER=X-Request-Id

DEFAULT_REQUEST_TIMEOUT_SECONDS=30
UPSTREAM_TIMEOUT_SECONDS=30
UPSTREAM_CONNECT_TIMEOUT_SECONDS=5
UPSTREAM_TLS_VERIFY=true
UPSTREAM_MAX_RESPONSE_BYTES=10485760

FEATURE_MCP=false
FEATURE_DIRECT_APISIX_PROXY=false
FEATURE_OIDC=false
FEATURE_EXTERNAL_POLICY_ENGINE=false
FEATURE_EXTERNAL_SECRET_STORE=false