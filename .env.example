GRANTORA_ENV=development
GRANTORA_PUBLIC_BASE_URL=http://localhost:9080
GRANTORA_API_URL=http://localhost:8080
GRANTORA_RUNTIME_URL=http://localhost:9080
GRANTORA_BIND_ADDR=0.0.0.0
GRANTORA_PORT=8080
GRANTORA_LOG_LEVEL=INFO
GRANTORA_JSON_LOGS=true

DATABASE_URL=postgresql+psycopg://grantora:grantora@postgres:5432/grantora
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_SSLMODE=prefer
MIGRATIONS_AUTO_RUN=true

POSTGRES_DB=grantora
POSTGRES_USER=grantora
POSTGRES_PASSWORD=grantora
POSTGRES_PORT=5432

APISIX_PUBLIC_URL=http://localhost:9080
APISIX_ADMIN_URL=http://apisix:9180
APISIX_ADMIN_KEY=change-me
APISIX_ADMIN_TIMEOUT_SECONDS=5
APISIX_SYNC_ENABLED=true
APISIX_SYNC_INTERVAL_SECONDS=30
APISIX_FAIL_CLOSED=true
APISIX_RUNTIME_UPSTREAM_NODE=grantora-api:8080
APISIX_RATE_LIMIT_COUNT=1000
APISIX_RATE_LIMIT_TIME_WINDOW=60

SECRET_ENCRYPTION_KEY=change-me-32-byte-base64-key
GRANTORA_AGENT_TOKEN_PEPPER=change-me-agent-token-pepper
ADMIN_BOOTSTRAP_TOKEN=replace-with-bootstrap-token-for-local-make-targets
GRANTORA_ADMIN_BOOTSTRAP_TOKEN_HASH=hmac-sha256:replace-with-bootstrap-token-hash

DEMO_OUTPUT_ENV=.grantora-demo.env
DEMO_WORKSPACE_SLUG=demo
DEMO_USER_EXTERNAL_ID=alice
DEMO_CAPABILITY_ID=mock.phonebook.search
DEMO_UPSTREAM_SECRET=demo-upstream-token

# Optional integration/e2e test variables. Leave commented to skip infrastructure tests.
# GRANTORA_INTEGRATION_DATABASE_URL=postgresql+psycopg://grantora:grantora@localhost:5432/grantora
# GRANTORA_INTEGRATION_APISIX_ADMIN_URL=http://localhost:9180
# GRANTORA_INTEGRATION_APISIX_ADMIN_KEY=change-me
# GRANTORA_RUN_E2E=1
# GRANTORA_RUN_BACKUP_RESTORE_SMOKE=1
# GRANTORA_E2E_API_URL=http://localhost:8080
# GRANTORA_E2E_RUNTIME_URL=http://localhost:9080
# GRANTORA_COMPOSE_COMMAND=docker compose
# GRANTORA_BACKUP_RESTORE_DUMP_PATH=.grantora-backup.dump
# GRANTORA_BACKUP_RESTORE_STARTUP_TIMEOUT_SECONDS=60
# GRANTORA_KEEP_BACKUP_DUMP=false

METRICS_ENABLED=true
METRICS_PATH=/metrics
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365
USAGE_RETENTION_DAYS=365
OTEL_TRACING_ENABLED=false
OTEL_SERVICE_NAME=grantora
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TIMEOUT_SECONDS=10
REQUEST_ID_HEADER=X-Request-Id
MAX_REQUEST_BODY_BYTES=1048576

DEFAULT_REQUEST_TIMEOUT_SECONDS=30
UPSTREAM_TIMEOUT_SECONDS=30
UPSTREAM_CONNECT_TIMEOUT_SECONDS=5
UPSTREAM_TLS_VERIFY=true
UPSTREAM_MAX_RESPONSE_BYTES=10485760
UPSTREAM_READ_RETRY_ATTEMPTS=2

FEATURE_MCP=false
FEATURE_DIRECT_APISIX_PROXY=false
FEATURE_OIDC=false
OIDC_ADMIN_SUBJECTS=
OIDC_SUBJECT_HEADER=X-Grantora-Admin-Subject
FEATURE_EXTERNAL_POLICY_ENGINE=false
FEATURE_EXTERNAL_SECRET_STORE=false