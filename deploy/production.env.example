GRANTORA_VERSION=0.1.0
GRANTORA_IMAGE=ghcr.io/grantora/grantora-api:0.1.0
GRANTORA_ENV=production
GRANTORA_PUBLIC_BASE_URL=https://gateway.example.test
GRANTORA_LOG_LEVEL=INFO
GRANTORA_JSON_LOGS=true

POSTGRES_DB=grantora
POSTGRES_USER=grantora
POSTGRES_PASSWORD=replace-with-long-random-postgres-password
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

APISIX_PUBLIC_PORT=9080
APISIX_ADMIN_KEY=replace-with-long-random-apisix-admin-key
APISIX_SYNC_ENABLED=true
APISIX_SYNC_INTERVAL_SECONDS=30
APISIX_FAIL_CLOSED=true
APISIX_RATE_LIMIT_COUNT=1000
APISIX_RATE_LIMIT_TIME_WINDOW=60

SECRET_ENCRYPTION_KEY=replace-with-generated-fernet-key
GRANTORA_AGENT_TOKEN_PEPPER=replace-with-long-random-token-pepper
GRANTORA_ADMIN_BOOTSTRAP_TOKEN_HASH=hmac-sha256:replace-with-bootstrap-token-hash

METRICS_ENABLED=true
AUDIT_RETENTION_DAYS=365
USAGE_RETENTION_DAYS=365
OTEL_TRACING_ENABLED=false
OTEL_SERVICE_NAME=grantora
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TIMEOUT_SECONDS=10
REQUEST_ID_HEADER=X-Request-Id
MAX_REQUEST_BODY_BYTES=1048576

DEFAULT_REQUEST_TIMEOUT_SECONDS=30
UPSTREAM_TIMEOUT_SECONDS=30
UPSTREAM_CONNECT_TIMEOUT_SECONDS=5
UPSTREAM_TLS_VERIFY=true
UPSTREAM_MAX_RESPONSE_BYTES=10485760
UPSTREAM_READ_RETRY_ATTEMPTS=2

FEATURE_OIDC=false
OIDC_ADMIN_SUBJECTS=
OIDC_SUBJECT_HEADER=X-Grantora-Admin-Subject
OIDC_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
FEATURE_EXTERNAL_SECRET_STORE=false